# MLBShell — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# API adapter mode: "mock" (default) | "fetch"
NEXT_PUBLIC_API_MODE=mock

# Base URL for your live MLB data API (only used when NEXT_PUBLIC_API_MODE=fetch)
NEXT_PUBLIC_API_BASE_URL=

# MLB Stats API key (Sportradar, MLB-StatsAPI, etc.)
NEXT_PUBLIC_MLB_API_KEY=

# Weather API key (OpenWeatherMap, WeatherAPI, etc.)
NEXT_PUBLIC_WEATHER_API_KEY=